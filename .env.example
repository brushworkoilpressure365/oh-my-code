# =============================================================================
# .env.example — template for local development secrets
#
# Copy this file to `.env` and fill in the keys you use. `.env` is gitignored;
# never commit real secrets. `.env.example` itself is tracked as the template.
#
# At startup, `oh-my-code` calls `dotenvy::dotenv()` which loads variables from
# `.env` in the current working directory into the process environment.
# Variables already set in your shell take precedence over `.env` values.
#
# Only the provider you actually use needs its key set. The active provider
# is chosen in `~/.config/oh-my-code/config.toml` under `[default]`.
# =============================================================================

# ---- Anthropic (default provider) -------------------------------------------
# Used when config.toml has `default.provider = "claude"`.
ANTHROPIC_API_KEY=

# ---- MiniMax via Anthropic-compatible endpoint ------------------------------
# Used when config.toml has `default.provider = "minimax-anthropic"`.
# This endpoint authenticates with `Authorization: Bearer <token>`.
ANTHROPIC_AUTH_TOKEN=

# ---- OpenAI / GPT-compatible ------------------------------------------------
# Used when config.toml has `default.provider = "openai"`.
OPENAI_API_KEY=

# ---- Zhipu BigModel ---------------------------------------------------------
# Used when config.toml has `default.provider = "zhipu"`.
ZHIPU_API_KEY=

# ---- MiniMax (OpenAI-compatible endpoint) -----------------------------------
# Used when config.toml has `default.provider = "minimax"`.
# Note: this is MiniMax's native OpenAI-compatible API, distinct from the
# `minimax-anthropic` provider above.
MINIMAX_API_KEY=
